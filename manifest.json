{
  "name": "AutoHub Extension",
  "description": "Chrome Extension that autofills login information and captcha for a certain bad college website...",
  "version": "1.0.3",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
        "16": "images/icon16.png",
        "32": "images/icon32.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "js": ["config.js", "scripts/content.js"],
      "matches": [
        "https://archershub.dlsu.edu.ph/",
        "https://archershub.dlsu.edu.ph/StudentDashboard",
        "https://archershub.dlsu.edu.ph/Enlistment/Index/2"
      ]
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ]
}